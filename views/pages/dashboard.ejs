        <!-- <div class="w-px h-6 bg-gray-200 my-auto"></div> -->
        <!-- <button
          class="px-4 py-3 text-gray-500 font-medium text-sm hover:text-gray-700"
        >
          Pending Orders
        </button>
        <div class="w-px h-6 bg-gray-200 my-auto"></div>
        <button
          class="px-4 py-3 text-gray-500 font-medium text-sm hover:text-gray-700"
        >
          Failed Orders
        </button>
        <div class="w-px h-6 bg-gray-200 my-auto"></div> -->
      </div>

      <!-- Dashboard Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <!-- Card Header -->
        <div class="flex justify-between items-start mb-8">
          <div>
            <h2 class="text-xl font-semibold text-[#1c3290] mb-2">Orders</h2>
            <!-- <h2 class="text-xl font-semibold text-[#1c3290] mb-2">
              Today's Confirmed Orders
            </h2> -->
            <p class="text-gray-400 text-sm">Real-time Amazon Purchase Sync</p>
          </div>
          <button
            class="bg-[#1c3290] hover:bg-[#142468] text-white px-5 py-2 rounded-full text-xs font-bold tracking-wide transition-colors"
          >
            LIVE XML FEED
          </button>
        </div>

        <!-- Table Headers -->
        <div
          class="grid grid-cols-5 gap-4 border-t border-b border-gray-100 py-4 mb-4"
        >
          <div
            class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
          >
            Order ID
          </div>
          <div
            class="text-xs font-semibold text-gray-500 uppercase tracking-wider text-center"
          >
            Product Details
          </div>
          <div
            class="text-xs font-semibold text-gray-500 uppercase tracking-wider text-center"
          >
            Customer
          </div>
          <div
            class="text-xs font-semibold text-gray-500 uppercase tracking-wider text-center"
