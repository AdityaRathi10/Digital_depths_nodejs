<div class="max-w-6xl mx-auto px-4 py-8">
  <!-- Page Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-light text-gray-500 mb-2">
      <span class="font-bold text-gray-900">Digital Depths</span>
    </h1>
    <p class="text-gray-400 text-lg">Your performance summary this week</p>
  </div>

  <div class="flex gap-6">
    <div class="basis-2/3 overflow-auto">
      <!-- Dashboard Card -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <!-- Card Header -->
        <div class="flex justify-between items-start mb-8">
          <div>
            <h2 class="text-xl font-semibold text-[#1c3290] mb-2">Orders</h2>
            <!-- <h2 class="text-xl font-semibold text-[#1c3290] mb-2">
              Today's Confirmed Orders
            </h2> -->
            <p class="text-gray-400 text-sm">Real-time Amazon Purchase Sync</p>
          </div>
        </div>

        <!-- Orders Dashboard Card -->
        <div
          class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 w-full"
        >
          <!-- Table Wrapper (Handles both X and Y scrolling) -->
          <div class="max-h-96 overflow-auto border border-gray-100 rounded-lg">
            <table class="w-full text-sm text-left">
              <thead
                class="text-xs text-gray-500 uppercase bg-gray-50 sticky top-0 z-10 shadow-sm"
              >
                <tr>
                  <th
                    scope="col"
                    class="px-6 py-4 font-semibold tracking-wider"
                  >
                    Order ID
                  </th>
                  <th
                    scope="col"
                    class="px-6 py-4 font-semibold tracking-wider"
                  >
                    Product Details
                  </th>
                  <th
                    scope="col"
                    class="px-6 py-4 font-semibold tracking-wider"
                  >
                    Customer
                  </th>
                  <th
                    scope="col"
                    class="px-6 py-4 font-semibold tracking-wider"
                  >
                    Total Price
                  </th>
                  <th
                    scope="col"
                    class="px-6 py-4 font-semibold tracking-wider text-right"
                  >
                    Status
                  </th>
                </tr>
              </thead>
              <tbody
                id="ordersListContainer"
                class="bg-white divide-y divide-gray-100"
              >
                <!-- Default Loading State -->
                <tr>
                  <td colspan="5" class="px-6 py-10 text-center">
                    <div
                      class="flex justify-center items-center space-x-3 text-gray-500"
                    >
                      <svg
                        class="animate-spin h-6 w-6 text-indigo-400"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                      >
                        <circle
                          class="opacity-25"
                          cx="12"
                          cy="12"
                          r="10"
                          stroke="currentColor"
                          stroke-width="4"
                        ></circle>
                        <path
                          class="opacity-75"
                          fill="currentColor"
                          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                        ></path>
                      </svg>
                      <span class="text-sm"
                        >Awaiting active transaction push...</span
                      >
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <div class="basis-1/3">
      <!-- Dashboard Card -->
      <div
        class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 min-w-md"
      >
        <!-- Card Header -->
        <div class="flex justify-between items-start mb-8">
          <div>
            <h2 class="text-xl font-semibold text-[#1c3290] mb-2">
              Live Email Automation Queue
            </h2>
            <!-- <h2 class="text-xl font-semibold text-[#1c3290] mb-2">
              Today's Confirmed Orders
            </h2> -->
            <!-- <p class="text-gray-400 text-sm">Real-time Amazon Purchase Sync</p> -->
          </div>
        </div>

        <!-- Dynamic List Container -->
        <div
          id="queueListContainer"
          class="space-y-3 max-h-80 overflow-y-auto pr-2"
        >
          <!-- Default Loading State (Matches your image) -->
          <div class="flex items-center space-x-3 text-gray-500 py-4">
            <svg
              class="animate-spin h-5 w-5 text-blue-600"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
            >
              <circle
                class="opacity-25"
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="4"
              ></circle>
              <path
                class="opacity-75"
                fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
              ></path>
            </svg>
            <span class="text-sm">Awaiting active transaction push...</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Import Socket.io -->
<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  // 1. Function to fetch emails and populate the queue
  async function loadEmailQueue() {
    const container = document.getElementById('queueListContainer');

    // Show loading state
    container.innerHTML = `
              <div class="flex items-center space-x-3 text-gray-500 py-4">
                  <svg class="animate-spin h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
                  </svg>
                  <span class="text-sm">Fetching accounts from database...</span>
              </div>
          `;

    try {
      const response = await fetch('/api/get-all-mails');
      const data = await response.json();

      if (data.success && data.emails.length > 0) {
                container.innerHTML = ''; // Clear loading spinner

                data.emails.forEach(item => {
                    const row = document.createElement('div');
                    row.className = 'flex justify-between items-center p-3 bg-gray-50 rounded-lg border border-gray-200';
                    row.innerHTML = `
                        <div class="flex flex-col truncate pr-3">
                            <span class="text-sm font-semibold text-gray-800 truncate">${item.email}</span>
                            <span class="text-xs text-gray-500">${item.status}</span>
                        </div>
                        <button onclick="triggerSavedSignIn('${item.email}')" class="bg-blue-800 hover:bg-blue-900 text-white text-xs font-semibold py-1.5 px-4 rounded-md shadow-sm transition-colors whitespace-nowrap">
                            Sign in
                        </button>
                    `;
                    container.appendChild(row);
                });
            } else {
                container.innerHTML = `<div class="text-gray-500 text-sm py-4">No accounts found in database.</div>`;
            }
    } catch (error) {
      container.innerHTML = `<div class="text-red-500 text-sm py-4">Failed to load emails. Check console.</div>`;
      console.error("Queue Load Error:", error);
    }
  }

  // 2. Function triggered when a user clicks "Sign in" on the list
  function triggerSavedSignIn(email) {
    // Clear the logging console for a fresh run
    const logConsole = document.getElementById('log-console');
    if (logConsole) logConsole.innerHTML = '';

    console.log(`Triggering sign in for: ${email}`);

    // Send the specific email to the backend to start the Playwright process
    socket.emit('trigger-saved-signin', { email: email });
  }

  // 3. Event Listener for the Refresh Button
  const refreshBtn = document.getElementById('refreshQueueBtn')
  if (refreshBtn) {
    document.getElementById('refreshQueueBtn').addEventListener('click', loadEmailQueue);
  }

  // 4. Automatically load the queue when the page loads
  window.addEventListener('DOMContentLoaded', () => {
    loadEmailQueue();
  });

  async function loadOrdersDashboard() {
    const container = document.getElementById('ordersListContainer');

    try {
      const response = await fetch('/api/orders');
      const data = await response.json();

      if (data.success && data.orders.length > 0) {
        container.innerHTML = '';

        data.orders.forEach(order => {
          // Determine Status Color
          let statusColor = 'text-gray-600';
          if (order.status.toLowerCase().includes('success')) statusColor = 'text-green-600';
          if (order.status.toLowerCase().includes('failed')) statusColor = 'text-red-600';

          const row = document.createElement('tr');
          row.className = 'hover:bg-gray-50 transition-colors';

          row.innerHTML = `
              <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-800">
                  ${order.orderId}
              </td>
              <td class="px-6 py-4 text-gray-600 max-w-[250px] truncate" title="${order.productName}">
                  ${order.productName}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-gray-500">
                  ${order.email}
              </td>
              <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-700">
                  ${order.price}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right font-semibold ${statusColor}">
                  ${order.status}
              </td>
          `;
          container.appendChild(row);
        });
      } else {
        // Fallback row spanning all 5 columns
        container.innerHTML = `
          <tr>
              <td colspan="5" class="px-6 py-8 text-center text-sm text-gray-400">
                  No orders found in database.
              </td>
          </tr>
      `;
      }
    } catch (error) {
      container.innerHTML = `<div class="text-red-400 text-sm text-center py-8">Failed to sync orders.</div>`;
    }
  }

  // Auto-load and set an interval to refresh the list every 15 seconds for a "Real-time" feel
  window.addEventListener('DOMContentLoaded', () => {
    loadOrdersDashboard();
    setInterval(loadOrdersDashboard, 15000);
  });
</script>
