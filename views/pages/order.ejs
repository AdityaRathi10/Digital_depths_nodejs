<style>
  /* Basic styling for the log box at the bottom */
  #log-console {
      margin-top: 20px;
      padding: 15px;
      background: #fff;
      color: #00ff00;
      height: 200px;
      overflow-y: scroll;
      font-family: monospace;
      border-radius: 5px;
  }
  .log-error { color: #ff4c4c; }
  .log-success { color: #00d4ff; }
  .log-info { color: #1e1e1e; }
</style>

<div
  class="max-w-5xl mx-auto mt-8 bg-white rounded-md shadow-sm border border-gray-200 overflow-hidden"
>
  <!-- Header -->
  <div class="bg-[#1c3290] text-white px-4 py-2.5 flex items-center">
    <span class="mr-2 text-xl">📦</span>
    <h2 class="text-base font-medium">
      Advanced Order Automation Configurator
    </h2>
  </div>

  <!-- Form Body -->
  <form action="/order" method="POST" class="p-6">
    <div class="space-y-6">
      <!-- Row 1 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label
            for="targetEmails"
            class="block text-sm font-semibold text-gray-700 mb-1.5"
            >Target Account Emails</label
          >
          <textarea
            id="targetEmails"
            name="targetEmails"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
            placeholder=""
            rows="1"
          ></textarea>
        </div>
        <div>
          <label
            for="productLink"
            class="block text-sm font-semibold text-gray-700 mb-1.5"
            >Product / Order Link</label
          >
          <input
            type="text"
            id="productLink"
            name="productLink"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder-gray-300"
            placeholder="https://www.amazon.in/dp/..."
          />
        </div>
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label
            for="maxPrice"
            class="block text-sm font-semibold text-gray-700 mb-1.5"
            >Max Product Price Limit (₹)</label
          >
          <input
            type="number"
            id="maxPrice"
            name="maxPrice"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder-gray-300"
            placeholder="e.g., 2000"
          />
        </div>
        <div>
          <label
            for="maxTotal"
            class="block text-sm font-semibold text-gray-700 mb-1.5"
            >Max Checkout Grand Total (₹)</label
          >
          <input
            type="number"
            id="maxTotal"
            name="maxTotal"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder-gray-300"
            placeholder="e.g., 10000"
          />
        </div>
      </div>

      <!-- Row 3 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label
            for="quantity"
            class="block text-sm font-semibold text-gray-700 mb-1.5"
            >Quantity Per Order</label
          >
          <input
            type="number"
            id="quantity"
            name="quantity"
            value="1"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-600"
          />
        </div>
        <div>
          <label
            for="ordersPerAccount"
            class="block text-sm font-semibold text-gray-700 mb-1.5"
            >Orders Per Account</label
          >
          <input
            type="number"
            id="ordersPerAccount"
            name="ordersPerAccount"
            value="1"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-600"
          />
        </div>
        <div>
          <label
            for="parallelWorkers"
            class="block text-sm font-semibold text-gray-700 mb-1.5"
            >Parallel Threads Workers</label
          >
          <input
            type="number"
            id="parallelWorkers"
            name="parallelWorkers"
            value="1"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-600"
          />
        </div>
      </div>

      <!-- Row 4 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Main Payment Method Dropdown -->
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Select Payment Method</label
          >
          <select
            id="paymentMethod"
            name="paymentMethod"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-700 bg-white"
          >
            <option value="COD">Cash On Delivery (COD)</option>
            <option value="NETBANKING">Net Banking</option>
            <option value="CARD">Credit/Debit Card (Saved)</option>
            <option value="UPI">UPI</option>
          </select>
        </div>

        <!-- Conditional: Net Banking Dropdown -->
        <div id="netBankingContainer" class="hidden mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Select Bank</label
          >
          <select
            id="bankName"
            name="bankName"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-700 bg-white"
          >
            <option value="State bank of India">State Bank of India</option>
            <option value="HDFC bank">HDFC Bank</option>
            <option value="ICICI bank">ICICI Bank</option>
            <option value="Axis Bank">Axis Bank</option>
            <option value="Kotak Mahindra Bank">Kotak Mahindra Bank</option>
            <option value="Punjab National Bank">Punjab National Bank</option>
            <option value="Bank of Baroda">Bank of Baroda</option>
            <option value="Canara Bank">Canara Bank</option>
          </select>
        </div>

        <!-- Conditional: UPI Input Field -->
        <div id="upiContainer" class="hidden mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Enter UPI ID</label
          >
          <input
            type="text"
            id="upiId"
            name="upiId"
            placeholder="e.g., yourname@bank"
            class="w-full border border-gray-200 rounded-md px-3 py-2 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-gray-700 bg-white"
          />
        </div>
      </div>

      <!-- Footer / Submit Button -->
      <div class="mt-8 pt-4 flex justify-end">
        <button
          type="submit"
          id="dispatchBtn"
          class="bg-[#1c3290] hover:bg-[#142468] text-white font-medium py-2.5 px-5 rounded-md shadow flex items-center transition-colors"
        >
          <span class="mr-2">🚀</span> Dispatch Parallel Order Engine
        </button>
      </div>
    </div>
  </form>
</div>

<!-- Real-time Log Output Area -->
<div id="log-console"></div>

<!-- Import Socket.io -->
<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const logConsole = document.getElementById('log-console');

  // Listen for logs from the Node.js backend
  socket.on('log', (data) => {
      const logEntry = document.createElement('div');
      logEntry.className = `log-${data.type}`;

      const timestamp = new Date().toLocaleTimeString();
      logEntry.innerText = `[${timestamp}] ${data.msg}`;

      logConsole.appendChild(logEntry);

      // Auto-scroll to bottom
      logConsole.scrollTop = logConsole.scrollHeight;
  });

  console.log("order.ejs script loaded");

  // Toggle visibility of payment sub-fields dynamically
  const paymentSelect = document.getElementById('paymentMethod');
  const netBankingContainer = document.getElementById('netBankingContainer');
  const upiContainer = document.getElementById('upiContainer');

  if (paymentSelect) {
      paymentSelect.addEventListener('change', (e) => {
          const selected = e.target.value;

          // Hide both initially
          if (netBankingContainer) netBankingContainer.classList.add('hidden');
          if (upiContainer) upiContainer.classList.add('hidden');

          // Show the relevant field based on selection
          if (selected === 'NETBANKING' && netBankingContainer) {
              netBankingContainer.classList.remove('hidden');
          } else if (selected === 'UPI' && upiContainer) {
              upiContainer.classList.remove('hidden');
          }
      });
  }

  // Handle Dispatch Button Click
  document.getElementById('dispatchBtn').addEventListener('click', (e) => {
      console.log("Dispatch button clicked");
      e.preventDefault();

      // Gather data from the form
      const config = {
          emails: document.getElementById('targetEmails').value,
          productLink: document.getElementById('productLink').value,
          maxPrice: document.getElementById('maxPrice').value,
          maxCheckoutTotal: document.getElementById('maxTotal').value,
          quantity: document.getElementById('quantity').value,
          ordersPerAccount: document.getElementById('ordersPerAccount').value,
          threads: document.getElementById('parallelWorkers').value,

          // Updated Payment Data
          paymentMethod: document.getElementById('paymentMethod').value,
          bankName: document.getElementById('bankName') ? document.getElementById('bankName').value : '',
          upiId: document.getElementById('upiId') ? document.getElementById('upiId').value : ''
      };

      console.log("Config gathered:", config);

      // Basic validation
      if(!config.emails || !config.productLink) {
          alert("Emails and Product Link are required.");
          return;
      }

      // Validation for UPI
      if (config.paymentMethod === 'UPI' && !config.upiId) {
          alert("Please enter a valid UPI ID before dispatching.");
          return;
      }

      // Clear previous logs
      logConsole.innerHTML = '';

      // Send to backend via WebSocket
      socket.emit('start-engine', config);
  });
</script>
